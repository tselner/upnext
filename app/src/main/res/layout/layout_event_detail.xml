<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout_event"
    android:layout_height="wrap_content"
    android:layout_width="match_parent"
    android:orientation="vertical">

        <TextView
            android:id="@+id/day_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:textColor="@color/font_date"
            android:textStyle="bold"
            android:textSize="12sp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

                <ImageView
                    android:id="@+id/event_background"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    android:src="@drawable/background_event" />

                <ImageView
                    android:id="@+id/event_color"
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:src="@drawable/background_color" />

                <LinearLayout
                    android:id="@+id/event_text"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingVertical="4dp"
                    android:paddingLeft="8dp"
                    android:paddingRight="4dp"
                    android:orientation="vertical">

                        <!-- title -->
                        <TextView
                            android:id="@+id/event_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/font_event"
                            android:textFontWeight="600"
                            android:textSize="12sp"/>

                        <!-- duration -->
                        <TextView
                            android:id="@+id/event_duration"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/font_event"
                            android:textSize="9sp" />
                </LinearLayout>
        </FrameLayout>
</LinearLayout>